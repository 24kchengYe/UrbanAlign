# ============================================================
# UrbanAlign 2.0 — .gitignore
# ============================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# ---------- Virtual environments ----------
AI4DATA/
.venv/
venv/
env/

# ---------- IDE ----------
.idea/
.vscode/
*.swp
*.swo
*~

# ---------- Environment / Secrets ----------
.env
.env.*
!.env.example

# ---------- Experiment outputs (large, regenerable) ----------
urbanalign_outputs/
urbanalign_outputs_*/
specs_outputs/

# ---------- Large data files ----------
*.npz
*.pkl
*.h5
*.pt
*.pth

# ---------- Reference papers (PDFs, too large for git) ----------
参考文献/
参考代码/

# ---------- LaTeX build artifacts ----------
*.aux
*.bbl
*.blg
*.brf
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz
texput.*
compile.log

# ---------- Arxiv submission bundle ----------
arxiv/
arxiv.zip
arxiv.pdf

# ---------- Paper compilation PDFs (keep source .tex, not compiled) ----------
ECCV_2026_Paper_Template/*.pdf
!ECCV_2026_Paper_Template/fig_*.pdf
!ECCV_2026_Paper_Template/human_*.pdf
!ECCV_2026_Paper_Template/eijkel2.pdf

# ---------- Internal project docs (not for public repo) ----------
CLAUDE.md
ECCV_2026_PAPER_CHINESE*.md
思路.txt

# ---------- Text extraction artifacts ----------
ECCV_2026_Paper_Template/_page*.txt
ECCV_2026_Paper_Template/abstract.txt
ECCV_2026_Paper_Template/main_text.txt

# ---------- Misc ----------
worktrees/
*.docx
*.zip
aiusv3.pdf
history/
.claude/

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini
