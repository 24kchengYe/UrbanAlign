# ============================================================
# UrbanAlign — .gitignore
# ============================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg

# ---------- Virtual environments ----------
.venv/
venv/
env/

# ---------- IDE ----------
.idea/
.vscode/
*.swp
*.swo
*~

# ---------- Environment / Secrets ----------
.env
.env.*
!.env.example

# ---------- Experiment outputs (large, regenerable) ----------
urbanalign_outputs/
urbanalign_outputs_*/
specs_outputs/

# ---------- Large data files ----------
*.npz
*.pkl
*.h5
*.pt
*.pth

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini
