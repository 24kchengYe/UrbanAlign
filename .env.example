# Dataset paths
# Place Pulse 2.0 dataset root (contains final_data_reliable_agg_N3.csv and final_photo_dataset/)
PLACE_PULSE_DIR=H:\RawData13-全球街景\mit place pulse\01 Place Pluse2.0数据集\01 Place Pulse 2.0论文数据集

