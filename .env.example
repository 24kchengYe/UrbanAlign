# UrbanAlign 2.0 — Environment Variables
# Copy this file to .env and fill in your values.

# LLM API configuration
URBANALIGN_API_KEY=your-api-key-here
URBANALIGN_BASE_URL=https://api.mindcraft.com.cn/v1/chat/completions
